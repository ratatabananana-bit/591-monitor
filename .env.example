# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/monitor

# Google Maps
GOOGLE_MAPS_API_KEY=your_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# App
SECRET_KEY=change_me_in_production
LOG_LEVEL=INFO

# Playwright profile path (inside container)
PLAYWRIGHT_PROFILE_PATH=/data/playwright-profile
