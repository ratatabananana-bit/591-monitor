# Copy this to .env and fill in your values
# (DATABASE_URL is set automatically by docker-compose, leave it out of .env)

# Required: Google Maps API key
# Enable these APIs: Geocoding API + Directions API
# https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=

# Required: Telegram bot token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Required: Your Telegram chat ID
# How to find it: message your bot, then open:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# Optional
LOG_LEVEL=INFO

# Set to false on secondary machines to avoid Telegram polling conflict
# Alerts (sending) still work — only the /subscribe bot commands are disabled
# TELEGRAM_POLLING=false
